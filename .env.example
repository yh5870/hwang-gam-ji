# 기상청 API (로컬 개발 시)
# VITE_KMA_API_KEY=

# 네이버 클라우드 플랫폼 → AI·NAVER API → Maps → Web Dynamic Map
# 콘솔에서 발급한 Application / 인증 정보의 ncpKeyId (구 Client ID)
# https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=...
VITE_NAVER_MAP_KEY_ID=

# Google Maps Platform Weather API (ASOS 실패 시 가시거리 폴백용)
# Google Cloud Console → APIs & Services → Credentials → API Key
# Weather API 사용 설정 필요: https://console.cloud.google.com/apis/library/weather.googleapis.com
# ※ 서버 전용 키 (Vercel 환경변수 GOOGLE_WEATHER_KEY로 설정, VITE_ 접두사 없음)
# GOOGLE_WEATHER_KEY=
